# ═══════ GoldenRay Energy — Environment Configuration ═══════

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ═══════ SUPABASE (Primary Database) ═══════
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Get this from: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use "Transaction pooler" for serverless, "Session pooler" for long-lived servers
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ═══════ JWT Authentication ═══════
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# ═══════ Email (SendGrid) ═══════
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=hello@goldenrayenergy.co.nz
EMAIL_FROM_NAME=GoldenRay Energy

# ═══════ SMTP Fallback ═══════
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# ═══════ PDF Generation ═══════
PDF_ENGINE=puppeteer

# ═══════ Google Maps (Client — set in client/.env) ═══════
# Enable "Places API" and "Maps JavaScript API" on this key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key


# ═══════ Twilio (SMS OTP) ═══════
# Get from: Twilio Console → Dashboard
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
